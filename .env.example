# How the Evidence Hub reads the immutable audit ledger.
#   fixtures  - read sample records from tests/fixtures (offline; no network, no SDK)
#   sandbox   - read from the public ledger sandbox (shared sandbox-public tenant)
#   live      - read from your own deployed ledger (set AUDIT_API_URL + AUDIT_READ_KEY)
LEDGER_SOURCE=sandbox

# Only used for LEDGER_SOURCE=live. Sandbox values are baked in for sandbox mode.
AUDIT_API_URL=
AUDIT_READ_KEY=

# Where the Evidence Hub stores its own evidence/readiness data.
# SQLite by default; swap for a postgresql+psycopg:// URL to use Postgres.
EVIDENCE_DB_URL=sqlite:///./data/evidence.db
