# ── How the Hub reads the immutable audit ledger ─────────────────────────────
#   fixtures  - read sample records from tests/fixtures (offline; no network)
#   sandbox   - read from the public ledger sandbox (shared sandbox-public tenant)
#   live      - read from your own deployed ledger (set AUDIT_API_URL + AUDIT_READ_KEY)
LEDGER_SOURCE=sandbox

# Only used for LEDGER_SOURCE=live. Sandbox values are baked in for sandbox mode.
AUDIT_API_URL=
AUDIT_READ_KEY=

# ── Where the Hub stores its own evidence data ───────────────────────────────
#   sqlite    - local file via SQLAlchemy (default)
#   dynamodb  - AWS single-table (requires EVIDENCE_TABLE_NAME)
EVIDENCE_STORE=sqlite
EVIDENCE_DB_URL=sqlite:///./data/evidence.db
EVIDENCE_TABLE_NAME=

# ── Auth (single internal deployment) ────────────────────────────────────────
# If set, every data route requires this as the x-api-key header. Unset = open.
EVIDENCE_ADMIN_KEY=
# AWS: a Secrets Manager ARN holding {"admin_api_key": ..., "ledger_read_key": ...};
# fills the admin key + ledger read key at cold start.
EVIDENCE_SECRET_ARN=

# ── Optional ─────────────────────────────────────────────────────────────────
# Repo evidence manifest the resolver auto-fills static gaps from.
EVIDENCE_MANIFEST_PATH=
# Link to the AI Audit Ledger dashboard, shown in the Hub dashboard header
# (blank string hides it).
EVIDENCE_LEDGER_DASHBOARD_URL=https://d2pfirb2397ixy.cloudfront.net
